---
interface Props {
  title?: string;
}
const { title = "Your Name" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="hoodie that hoodies. sometimes a hoodie hoodies, sometimes it won't. projects, experiments, and things built for fun." />
    <meta name="keywords" content="hoodie, hoodies, hoodie that hoodies, the hoodie that hoodies, hoodie portfolio, hoodie projects, hoodie codes, hoodie builds" />
    <meta property="og:title" content="the hoodie that hoodies" />
    <meta property="og:description" content="sometimes a hoodie hoodies. sometimes it won't." />
    <meta property="og:url" content="https://www.thehoodiethathoodies.com/" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="the hoodie that hoodies" />
    <meta name="twitter:description" content="sometimes a hoodie hoodies. sometimes it won't." />
    <link rel="canonical" href="https://www.thehoodiethathoodies.com/" />
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "hoodie",
        "url": "https://www.thehoodiethathoodies.com",
        "description": "hoodie that hoodies. projects, experiments, and things built for fun.",
        "sameAs": [
          "https://github.com/FammyFams"
        ]
      }
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-H53Q49BN0G"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-H53Q49BN0G');
    </script>
    <style is:global>
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Space+Grotesk:wght@400;500;600;700&display=swap');

      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --bg: #0e0e0e;
        --bg-card: #161616;
        --bg-card-hover: #1e1e1e;
        --border: #2a2a2a;
        --border-hover: #3a3a3a;
        --text: #f0f0f0;
        --text-muted: #888;
        --text-dim: #555;
        --accent: #d4f14e;
        --accent-dim: #a8c03d;
        --font-sans: 'Inter', system-ui, sans-serif;
        --font-display: 'Space Grotesk', system-ui, sans-serif;
      }

      html {
        background: var(--bg);
        color: var(--text);
        font-family: var(--font-sans);
        font-size: 16px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      body {
        min-height: 100vh;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      ::selection {
        background: var(--accent);
        color: #0e0e0e;
      }

      ::-webkit-scrollbar {
        width: 6px;
      }
      ::-webkit-scrollbar-track {
        background: var(--bg);
      }
      ::-webkit-scrollbar-thumb {
        background: var(--border);
        border-radius: 3px;
      }
    </style>
  </head>
  <body>
    <canvas id="parallax-specs" aria-hidden="true"></canvas>
    <slot />
    <script>
      const canvas = document.getElementById('parallax-specs') as HTMLCanvasElement;
      const ctx = canvas.getContext('2d')!;

      const colors = ['#d4f14e', '#4ecef1', '#f14ea8', '#f1a84e', '#8b5cf6'];
      const specs: { x: number; y: number; r: number; color: string; speed: number; opacity: number }[] = [];
      const SPEC_COUNT = 60;

      function resize() {
        canvas.width = window.innerWidth;
        canvas.height = document.documentElement.scrollHeight;
      }

      function init() {
        resize();
        specs.length = 0;
        for (let i = 0; i < SPEC_COUNT; i++) {
          specs.push({
            x: Math.random() * canvas.width,
            y: Math.random() * canvas.height,
            r: Math.random() * 3 + 1.5,
            color: colors[Math.floor(Math.random() * colors.length)],
            speed: Math.random() * 0.4 + 0.1,
            opacity: Math.random() * 0.4 + 0.15,
          });
        }
      }

      function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        const scrollY = window.scrollY;
        for (const s of specs) {
          const y = s.y - scrollY * s.speed;
          ctx.beginPath();
          ctx.arc(s.x, y, s.r, 0, Math.PI * 2);
          ctx.fillStyle = s.color;
          ctx.globalAlpha = s.opacity;
          ctx.fill();
        }
        ctx.globalAlpha = 1;
        requestAnimationFrame(draw);
      }

      init();
      draw();
      window.addEventListener('resize', init);
    </script>
    <style is:global>
      #parallax-specs {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 0;
      }
      body > *:not(#parallax-specs) {
        position: relative;
        z-index: 1;
      }
    </style>
  </body>
</html>
